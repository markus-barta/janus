{
  "schema_version": 1,
  "release": {
    "cases": 256,
    "max_input_bytes": 8192,
    "max_collection_items": 64,
    "max_depth": 8,
    "max_shrink_iterations": 4096,
    "max_flat_map_regenerations": 100000,
    "target_timeout_seconds": 240
  },
  "targets": [
    {
      "id": "core-security-contracts",
      "package": "janus-core",
      "test": "security_properties"
    },
    {
      "id": "conformance-boundaries",
      "package": "janus-conformance",
      "test": "property_conformance"
    },
    {
      "id": "warden-tool-boundary",
      "package": "janus-warden",
      "filter": "security_property_warden_tools"
    },
    {
      "id": "provider-allowlist",
      "package": "janus-providers",
      "filter": "security_property_provider_allowlist"
    },
    {
      "id": "audit-jsonl-boundary",
      "package": "janus-local",
      "filter": "security_property_audit_jsonl"
    },
    {
      "id": "cli-argv-boundary",
      "package": "janusd",
      "filter": "security_property_cli_argv"
    }
  ]
}
