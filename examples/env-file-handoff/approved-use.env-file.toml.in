[[env_files]]
id = "@PROFILE_ID@"
secret_ref = "@SECRET_REF@"
executor = "@EXECUTOR@"
destination = "@DESTINATION@"
env = "@ENV_NAME@"
output = "@OUTPUT_PATH@"

[env_files.consumer]
consumer_ref = "@CONSUMER_REF@"
kind = "service"
owner = "@CONSUMER_OWNER@"
environment = "@CONSUMER_ENVIRONMENT@"
reload = "none"
validation = ["@VALIDATION_PROBE@"]
supports_dual_value = false
blast_radius = "@BLAST_RADIUS@"
