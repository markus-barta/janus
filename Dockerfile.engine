FROM rust:1.97.1-alpine3.23@sha256:c4a364ddbf684fe038e6fa6a4f25b30c8dc85247423e0e660676ece0d17be4a2 AS build

WORKDIR /src
ARG TARGETARCH
COPY Cargo.toml Cargo.lock rust-toolchain.toml ./
COPY crates ./crates
COPY config/release-channels/v1.json ./config/release-channels/v1.json
COPY config/authorization/role-matrix-v1.json ./config/authorization/role-matrix-v1.json
RUN set -eux; \
    case "${TARGETARCH}" in amd64|arm64) ;; *) echo "unsupported target arch: ${TARGETARCH}" >&2; exit 1 ;; esac; \
    cargo build --locked --release -p janusd -p janus-host -p janus-warden --bins; \
    mkdir -p \
      /out/rootfs/etc/janus \
      /out/rootfs/etc/ssl/certs \
      /out/rootfs/run/janus/age \
      /out/rootfs/run/janus/permits \
      /out/rootfs/tmp \
      /out/rootfs/usr/local/bin \
      /out/rootfs/var/lib/janus/secrets; \
    cp target/release/janusd /out/rootfs/usr/local/bin/janusd; \
    cp target/release/janusd-use /out/rootfs/usr/local/bin/janusd-use; \
    cp target/release/janusd-admin /out/rootfs/usr/local/bin/janusd-admin; \
    cp target/release/janusd-web-transactiond /out/rootfs/usr/local/bin/janusd-web-transactiond; \
    cp target/release/janus-host-executor /out/rootfs/usr/local/bin/janus-host-executor; \
    cp target/release/janus-warden /out/rootfs/usr/local/bin/janus-warden; \
    cp config/release-channels/v1.json /out/rootfs/etc/janus/release-channels-v1.json; \
    cp /etc/ssl/certs/ca-certificates.crt /out/rootfs/etc/ssl/certs/ca-certificates.crt

FROM scratch

LABEL org.opencontainers.image.title="Janus Rust engine"
LABEL org.opencontainers.image.description="Static Janus secret-handling binaries with no runtime OS packages or shell"
LABEL org.opencontainers.image.source="https://github.com/markus-barta/janus"
LABEL org.opencontainers.image.licenses="AGPL-3.0-only"
LABEL org.opencontainers.image.base.name="scratch"

COPY --chown=65532:65532 --from=build /out/rootfs /

ENV PATH="/usr/local/bin"
ENV SSL_CERT_FILE="/etc/ssl/certs/ca-certificates.crt"
USER 65532:65532
ENTRYPOINT ["/usr/local/bin/janusd-use"]
CMD ["--help"]
